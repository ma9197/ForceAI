# ForceAI runs WITHOUT any .env — the dashboard's first-run wizard collects your API keys and
# stores them on your own server. This file is only for advanced / hosting overrides. Copy it to
# .env if you want to set any of these.

# ---- API keys (optional here — easiest to paste them in the dashboard's setup wizard / Settings) ----
# Anthropic is required for the bot to think; the other two unlock optional features.
# ANTHROPIC_API_KEY=sk-ant-...
# ELEVENLABS_API_KEY=...   # unlocks spoken voice notes
# GEMINI_API_KEY=...       # unlocks image / meme generation (free tier available)

# ---- Hosting (only needed when exposing the dashboard online, not for local use) ----
# Bind to all interfaces so the host can route to it. Leave unset for local-only.
# HOST=0.0.0.0
# Password that protects the dashboard. STRONGLY RECOMMENDED when HOST=0.0.0.0 — without it,
# anyone who reaches the page can enter keys and spend your money. Username defaults to "admin".
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=change-me-to-something-long-and-random

# ---- Public demo (showcase) ----
# DEMO_MODE=1 runs a read-only demo: fake seeded data, no real WhatsApp, no keys, in-memory DB.
# DEMO_MODE=1

# Optional overrides
# PORT=3008
