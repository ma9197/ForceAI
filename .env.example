# Copy to .env and fill in
ANTHROPIC_API_KEY=sk-ant-...

# Optional: enables AI voice notes (enable + pick voice in dashboard Settings)
# ELEVENLABS_API_KEY=...

# Optional: enables AI image generation via Google Gemini (free tier: 500 images/day)
# Get a key at https://aistudio.google.com/apikey — enable + configure in Settings
# GEMINI_API_KEY=...

# ---- Hosting (only needed when running online, not for local use) ----
# Bind to all interfaces so the host can route to it. Leave unset for local-only.
# HOST=0.0.0.0
# Password that protects the dashboard. REQUIRED when HOST=0.0.0.0 so only you get in.
# Username defaults to "admin". Pick a long random password.
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=change-me-to-something-long-and-random

# Optional overrides
# PORT=3008
