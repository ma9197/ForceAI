{
  "name": "forceai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ForceAI - WhatsApp group AI bot with web dashboard",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && npm run build:ui",
    "build:ui": "cd ui && vite build",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "ui:dev": "cd ui && vite"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "@hapi/boom": "^10.0.1",
    "baileys": "7.0.0-rc13",
    "better-sqlite3": "^12.0.0",
    "dotenv": "^17.0.0",
    "fastify": "^5.0.0",
    "pino": "^9.0.0",
    "qrcode": "^1.5.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^24.0.0",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
